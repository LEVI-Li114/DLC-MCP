TENCENTCLOUD_SECRET_ID=replace-me
TENCENTCLOUD_SECRET_KEY=replace-me
TENCENTCLOUD_REGION=ap-guangzhou
WEDATA_VERSION=2025-08-06
WEDATA_PROJECT_ID=replace-me

# Local asset store and raw sync dumps.
DLC_MCP_DB=/data/dlc-mcp/assets.db
DLC_MCP_SYNC_DIR=/data/dlc-mcp/sync
DLC_MCP_PYTHON=python3

# WeData pagination and table catalog sync.
WEDATA_PAGE_SIZE=100
WEDATA_SYNC_TABLE_CATALOG=1

# Optional. Set to 1 to sync real ListTable/GetTableColumns/ListLineage/ListQualityRules metadata.
# Start with a small limit, then raise it after sync is stable.
WEDATA_SYNC_METADATA=0
WEDATA_METADATA_TABLE_LIMIT=50
WEDATA_METADATA_TABLES=
WEDATA_METADATA_WORKERS=4

# Optional. Set to 1 to sync ListDataSources and GetDataSourceRelatedTasks.
WEDATA_SYNC_DATA_SOURCES=0

# Optional. Set to 1 after ListTaskInstances payload is confirmed for your tenant.
# Keep keywords/max pages bounded for the first production runs.
WEDATA_SYNC_INSTANCES=0
WEDATA_INSTANCE_LOOKBACK_DAYS=2
WEDATA_INSTANCE_KEYWORDS=
WEDATA_INSTANCE_MAX_PAGES=50
WEDATA_INSTANCE_START=
WEDATA_INSTANCE_END=
WEDATA_INSTANCE_TIMEZONE=UTC+8

# Optional. Partition facts for get_table_partition_profile.
WEDATA_SYNC_PARTITIONS=0
WEDATA_PARTITION_ACTION=ListTablePartitions
WEDATA_PARTITION_DATE=

# Sync post-checks. Keep enabled so every run reports health, coverage, and top gaps.
DLC_MCP_SYNC_HEALTH_CHECK=1
DLC_MCP_SYNC_GAP_TYPES=fields,lineage,quality,tasks,runs,data_source
DLC_MCP_SYNC_GAP_LIMIT=20

# Central scheduler. deploy/sync-wedata-managed.sh runs daily at 05:00 and
# switches to monthly calibration on the last day of each month.
DLC_MCP_SYNC_MODE=auto
DLC_MCP_DAILY_SYNC_TABLE_CATALOG=1
DLC_MCP_DAILY_SYNC_METADATA=1
DLC_MCP_DAILY_NEW_ASSET_STRICT=1
DLC_MCP_DAILY_METADATA_TABLE_LIMIT=100000
DLC_MCP_DAILY_SYNC_DATA_SOURCES=1
DLC_MCP_DAILY_SYNC_INSTANCES=1
DLC_MCP_DAILY_SYNC_PARTITIONS=1
DLC_MCP_DAILY_INSTANCE_KEYWORDS=
DLC_MCP_MONTHLY_SYNC_TABLE_CATALOG=1
DLC_MCP_MONTHLY_SYNC_METADATA=1
DLC_MCP_MONTHLY_METADATA_TABLE_LIMIT=100000
DLC_MCP_MONTHLY_SYNC_DATA_SOURCES=1
DLC_MCP_MONTHLY_SYNC_INSTANCES=1
DLC_MCP_MONTHLY_SYNC_PARTITIONS=1
DLC_MCP_MONTHLY_INSTANCE_LOOKBACK_DAYS=2

# HTTP Gateway for user access.
DLC_MCP_GATEWAY_HOST=0.0.0.0
DLC_MCP_GATEWAY_PORT=8787
DLC_MCP_GATEWAY_TOKEN=replace-with-random-token
